# .htaccess — kazna-gov.ru (Apache/cPanel)
Options -Indexes
DirectoryIndex index.html
DirectorySlash Off

# --- кодировка UTF-8 (charset в Content-Type для всех text/*) ---
AddDefaultCharset utf-8

# --- gzip-сжатие ---
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/xml application/javascript application/json image/svg+xml
</IfModule>

# --- security-заголовки ---
<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
# HSTS: основной хост уже форсит HTTPS (см. RewriteCond ниже). max-age 1 год.
# includeSubDomains и preload — включить ПОСЛЕ проверки, что api./cf. отдают HTTPS.
Header always set Strict-Transport-Security "max-age=31536000"
# Отключаем неиспользуемые браузерные фичи
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
# CSP пока в Report-Only: НЕ ломает сайт, только логирует нарушения в консоль.
# После недели наблюдения без ложных срабатываний — сменить на Content-Security-Policy (enforce).
Header always set Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://mc.yandex.ru https://top-fwz1.mail.ru; connect-src 'self' https://api.kazna-gov.ru https://cf.kazna-gov.ru https://mc.yandex.ru https://forms.tildaapi.pro https://top-fwz1.mail.ru; frame-src 'self'"
</IfModule>
<IfModule mod_headers.c>
<FilesMatch "\.(woff2)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
</IfModule>
RewriteEngine On


# --- /policy — дубль политики ПДн → 301 на канонический URL (R1.05) ---
RewriteRule ^policy/?$ /personal_data_policy [R=301,L]

# --- /stuff — дубль trust-интента (команда) → 301 на автор-страницу эксперта (консолидация, Конституция гл.7) ---
RewriteRule ^stuff/?$ /expert/stella [R=301,L]

# --- Force HTTPS (кроме ACME-challenge LetsEncrypt) ---
RewriteCond %{HTTPS} off
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# --- www -> без www (канон non-www) ---
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

ErrorDocument 404 /404.html


# --- RSS блога -> живой фид на api ---
RewriteRule ^blog/rss/?$ https://api.kazna-gov.ru/feed.xml [R=301,L]

# --- 301: law-сущности /entity/ — транслитерация слагов (кириллица → латиница) ---
# Старые кириллические URL публиковались в llms-entities.txt; файлы переименованы gen-graph.js.
RewriteRule ^entity/law-44-фз\.json$ /entity/law-44-fz.json [R=301,L]
RewriteRule ^entity/law-223-фз\.json$ /entity/law-223-fz.json [R=301,L]
RewriteRule ^entity/law-275-фз\.json$ /entity/law-275-fz.json [R=301,L]
RewriteRule ^entity/law-63-фз\.json$ /entity/law-63-fz.json [R=301,L]
RewriteRule ^entity/law-бк-рф-ст-2422224226\.json$ /entity/law-bk-rf-st-2422224226.json [R=301,L]
RewriteRule ^entity/law-гк-рф-ст-185189\.json$ /entity/law-gk-rf-st-185189.json [R=301,L]
RewriteRule ^entity/law-ежегодный-закон-о-федеральном-бюджете\.json$ /entity/law-ezhegodnyy-zakon-o-federalnom-byudzhete.json [R=301,L]
RewriteRule ^entity/law-коап-рф-ст-1514\.json$ /entity/law-koap-rf-st-1514.json [R=301,L]
RewriteRule ^entity/law-коап-рф-ст-1537\.json$ /entity/law-koap-rf-st-1537.json [R=301,L]
RewriteRule ^entity/law-нк-рф-гл-21\.json$ /entity/law-nk-rf-gl-21.json [R=301,L]
RewriteRule ^entity/law-пп-1465\.json$ /entity/law-pp-1465.json [R=301,L]
RewriteRule ^entity/law-пп-2053\.json$ /entity/law-pp-2053.json [R=301,L]
RewriteRule ^entity/law-приказ-минфина-214н\.json$ /entity/law-prikaz-minfina-214n.json [R=301,L]
RewriteRule ^entity/law-приказ-минцифры-1001\.json$ /entity/law-prikaz-mintsifry-1001.json [R=301,L]
RewriteRule ^entity/law-приказ-фк-21н\.json$ /entity/law-prikaz-fk-21n.json [R=301,L]
RewriteRule ^entity/law-приказ-фк-44н\.json$ /entity/law-prikaz-fk-44n.json [R=301,L]

