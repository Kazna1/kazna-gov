# --- URL без слеша -> его index.html без редиректа (no-slash = 200, совпадает с canonical) ---
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+[^/])$ /$1/index.html [L]
# доп. кэш статики
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 30 days"
ExpiresByType application/javascript "access plus 30 days"
ExpiresByType image/webp "access plus 30 days"
ExpiresByType image/png "access plus 30 days"
ExpiresByType image/jpeg "access plus 30 days"
ExpiresByType image/svg+xml "access plus 30 days"
AddType font/woff2 .woff2
ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
Redirect 301 /uslugi/rezerv-kaznacheyskogo-scheta /services/reserve
Redirect 301 /uslugi/otkrytie-kaznacheyskogo-scheta /services/open
Redirect 301 /uslugi/soprovozhdenie-postoplata /services/postpayment
