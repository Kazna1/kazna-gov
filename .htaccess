# .htaccess — kazna-gov.ru (Apache/cPanel)
Options -Indexes
DirectoryIndex index.html
DirectorySlash Off

# --- gzip-сжатие ---
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/xml application/javascript application/json image/svg+xml
</IfModule>

# --- security-заголовки ---
<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
RewriteEngine On

# --- Force HTTPS (кроме ACME-challenge LetsEncrypt) ---
RewriteCond %{HTTPS} off
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# --- www -> без www (канон non-www) ---
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

ErrorDocument 404 /404.html


# --- RSS блога -> живой фид на api ---
RewriteRule ^blog/rss/?$ https://api.kazna-gov.ru/feed.xml [R=301,L]
# --- 301 редиректы (перенос с Tilda) ---
RewriteRule ^how_to_open/?$ /blog/how_to_open [R=301,L]
RewriteRule ^tofk/?$ /blog/tofk [R=301,L]
RewriteRule ^codes/?$ /blog/codes [R=301,L]
# --- GSC 404 -> 301 (корректные паттерны) ---
RewriteRule ^uslugi/soprovozhdenie-pod-kluch/?$ /services/conduct [R=301,L]
RewriteRule ^files/obrazec-naznacheniya-platezha\.docx$ /blog/naznachenie-platezha-kaznachejstvo [R=301,L]
RewriteRule ^blog/kak-rabotaet-kaznachejskoe-soprovozhdenie-kontraktov/?$ /blog/kaznacheyskoe-soprovozhdenie-dlya-chaynikov [R=301,L]
RewriteRule ^blog/kaznacheiskoe-soprovozhdenie-s-kakoi-summy-2026/?$ /blog/kaznacheyskoe-soprovozhdenie-44-fz-2026-polnyy-gid [R=301,L]
